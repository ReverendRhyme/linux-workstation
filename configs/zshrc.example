# ZSH configuration template for Pop!_OS
# Copy to ~/.zshrc after Oh My Zsh installation

export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="agnoster"
plugins=(git zsh-autosuggestions zsh-syntax-highlighting docker docker-compose)
source $ZSH/oh-my-zsh.sh

# User aliases
alias ll="ls -la"
alias la="ls -A"
alias l="ls -CF"
alias gs="git status"
alias gp="git pull"
alias gd="git diff"
alias gdc="git diff --cached"

# Gaming shortcuts
alias gamemode="gamemoderun"
alias mh="mangohud"

# System shortcuts
alias update="sudo apt update && sudo apt upgrade -y"
alias cleanup="sudo apt autoremove -y && sudo apt autoclean -y"

# Docker shortcuts
alias dps="docker ps"
alias di="docker images"
