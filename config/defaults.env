# Portable defaults for Pop!_OS workstation setup
# Override any value in config/deployment.local.env

DEPLOY_PROFILE=full
INSTALL_MODE=fresh

# Repo metadata
REPO_NAME=linux-workstation
REPO_URL=https://github.com/<your-user>/<your-repo>.git

# Drive + mount defaults
MOUNT_GAMES=/mnt/games
MOUNT_STORAGE=/mnt/storage
MOUNT_BACKUPS=/mnt/backups

# Optional software intent
USE_FUSION360=no
ENABLE_CLOUD_SETUP=no
