# Local deployment overrides (copy to config/deployment.local.env)
# This file is safe to commit and contains placeholders only.

DEPLOY_PROFILE=full
INSTALL_MODE=fresh

# Optional drive device hints (leave empty to decide later)
OS_DRIVE=
GAMES_DRIVE=
STORAGE_DRIVE=
BACKUP_DRIVE=

# Mount points
MOUNT_GAMES=/mnt/games
MOUNT_STORAGE=/mnt/storage
MOUNT_BACKUPS=/mnt/backups

# Optional software intent
USE_FUSION360=no
FUSION360_PROVIDER=codeberg-script
FUSION360_FALLBACK_PROVIDER=bottles
FUSION360_CHANNEL=stable
FUSION360_ENABLE_PROTON=no
FUSION360_PROTON_VERSION=GE-Proton10-32
ENABLE_CLOUD_SETUP=no
